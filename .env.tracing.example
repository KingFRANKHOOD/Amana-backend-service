# Distributed Tracing Configuration
# Copy this to your .env file and configure as needed

# OpenTelemetry Exporters
JAEGER_ENDPOINT=http://localhost:14268/api/traces
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
PROMETHEUS_PORT=9464

# Service Identification
OTEL_SERVICE_NAME=amana-backend
OTEL_EXPORTER_JAEGER_AGENT_HOST=localhost
OTEL_EXPORTER_JAEGER_AGENT_PORT=6831

# Logging Configuration
NODE_ENV=development
LOG_LEVEL=debug

# Existing Configuration (keep your existing values)
DATABASE_URL=your_database_url_here
JWT_SECRET=your_jwt_secret_here
REDIS_URL=redis://localhost:6379
STELLAR_RPC_URL=your_stellar_rpc_url
AMANA_ESCROW_CONTRACT_ID=your_contract_id
USDC_CONTRACT_ID=your_usdc_contract_id
